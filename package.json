{
  "name": "ivgam-vault",
  "version": "1.0.4",
  "description": "Ivgam Vault CLI password manager",
  "main": "dist/index.js",
  "bin": {
    "vault": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc",
    "postbuild": "node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "prepack": "npm run clean && npm run build",
    "start": "node ./dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "cli",
    "vault",
    "password",
    "encryption"
  ],
  "author": "Artyom Galay | Ivgam",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/node": "^24.6.2",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "clipboardy": "^5.0.0",
    "dotenv": "^17.2.3"
  }
}
